  {
    "id": "rule-003",
    "label": "creeper-cousin",
    "name": {
      "zh": "苦力怕的表弟",
      "en": "Creeper's Cousin"
    },
    "description": {
      "zh": "整块棋盘是一张上下颠倒的苦力怕脸：脸部数字不小于7，其余不大于2。这天他有点头重脚轻。",
      "en": "The whole board is an upside-down Creeper face — face digits at least 7, background at most 2. He's having a rough day."
    },
    "baseScore": 150,
    "matcherKey": "pattern-matcher",
    "params": {
      "pattern": [
        ".#..#.",
        ".####.",
        ".####.",
        "..##..",
        "##..##",
        "##..##"
      ],
      "symbolValues": {
        "#": [7, 8, 9],
        ".": [0, 1, 2]
      },
      "coefficient": {
        "type": "match-count"
      }
    }
  },
  {
